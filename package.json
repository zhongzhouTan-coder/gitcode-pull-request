{
  "name": "gitcode-pull-request",
  "displayName": "GitCode Pull Requests",
  "description": "GitCode pull request integration for Visual Studio Code",
  "version": "0.0.5",
  "publisher": "zhongzhoutan-coder",
  "license": "SEE LICENSE IN LICENSE",
  "preview": true,
  "icon": "media/gitcode.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhongzhouTan-coder/gitcode-pull-request.git"
  },
  "homepage": "https://github.com/zhongzhouTan-coder/gitcode-pull-request#readme",
  "bugs": {
    "url": "https://github.com/zhongzhouTan-coder/gitcode-pull-request/issues"
  },
  "keywords": [
    "gitcode",
    "pull request",
    "pull requests",
    "issues",
    "scm",
    "code review",
    "git"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitcode-pull-requests",
          "title": "GitCode Pull Requests",
          "icon": "media/gitcode.svg"
        }
      ]
    },
    "views": {
      "gitcode-pull-requests": [
        {
          "id": "pr:gitcode",
          "name": "Pull Requests"
        },
        {
          "id": "gitcode:createPullRequestWebview",
          "name": "Create Pull Request",
          "type": "webview"
        },
        {
          "id": "issues:gitcode",
          "name": "Issues"
        }
      ]
    },
    "commands": [
      {
        "command": "gitcode.signIn",
        "title": "GitCode: Sign In",
        "icon": "$(sign-in)"
      },
      {
        "command": "gitcode.refreshPullRequests",
        "title": "GitCode: Refresh Pull Requests",
        "icon": "$(refresh)"
      },
      {
        "command": "gitcode.openPullRequest",
        "title": "GitCode: Open Pull Request",
        "icon": "$(eye)"
      },
      {
        "command": "gitcode.openPullRequestOnWeb",
        "title": "GitCode: Open Pull Request On Web",
        "icon": "$(globe)"
      },
      {
        "command": "gitcode.refreshPullRequest",
        "title": "GitCode: Refresh Pull Request"
      },
      {
        "command": "gitcode.openPullRequestFile",
        "title": "GitCode: Open Pull Request File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitcode.openPullRequestFileOnWeb",
        "title": "GitCode: Open File On Web",
        "icon": "$(globe)"
      },
      {
        "command": "gitcode.refreshPullRequestFiles",
        "title": "GitCode: Refresh Pull Request Files",
        "icon": "$(refresh)"
      },
      {
        "command": "gitcode.setPullRequestFilesLayoutTree",
        "title": "GitCode: Show Files as Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitcode.setPullRequestFilesLayoutFlat",
        "title": "GitCode: Show Files as Flat List",
        "icon": "$(list-flat)"
      },
      {
        "command": "gitcode.refreshIssues",
        "title": "GitCode: Refresh Issues",
        "icon": "$(refresh)"
      },
      {
        "command": "gitcode.createIssue",
        "title": "GitCode: Create Issue",
        "icon": "$(add)"
      },
      {
        "command": "gitcode.openIssue",
        "title": "GitCode: Open Issue",
        "icon": "$(eye)"
      },
      {
        "command": "gitcode.openIssueOnWeb",
        "title": "GitCode: Open Issue On Web",
        "icon": "$(globe)"
      },
      {
        "command": "gitcode.copyIssueUrl",
        "title": "GitCode: Copy Issue URL",
        "icon": "$(copy)"
      },
      {
        "command": "gitcode.refreshIssue",
        "title": "GitCode: Refresh Issue"
      },
      {
        "command": "gitcode.usePullRequestAsCopilotContext",
        "title": "GitCode: Use Pull Request as Copilot Context",
        "icon": "$(sparkle)"
      },
      {
        "command": "gitcode.useIssueAsCopilotContext",
        "title": "GitCode: Use Issue as Copilot Context",
        "icon": "$(sparkle)"
      },
      {
        "command": "gitcode.createBranchForIssue",
        "title": "GitCode: Create Branch for Issue",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitcode.createPullRequest",
        "title": "GitCode: Create Pull Request",
        "icon": "$(add)"
      },
      {
        "command": "gitcode.editPullRequest",
        "title": "GitCode: Edit Pull Request",
        "icon": "$(edit)"
      },
      {
        "command": "gitcode.pullRequest.addReviewer",
        "title": "GitCode: Add Reviewer to Pull Request"
      },
      {
        "command": "gitcode.pullRequest.removeReviewer",
        "title": "GitCode: Remove Reviewer from Pull Request"
      },
      {
        "command": "gitcode.pullRequest.addTester",
        "title": "GitCode: Add Tester to Pull Request"
      },
      {
        "command": "gitcode.pullRequest.removeTester",
        "title": "GitCode: Remove Tester from Pull Request"
      },
      {
        "command": "gitcode.pullRequest.addAssignee",
        "title": "GitCode: Add Approver to Pull Request"
      },
      {
        "command": "gitcode.pullRequest.removeAssignee",
        "title": "GitCode: Remove Approver from Pull Request"
      },
      {
        "command": "gitcode.submitPullRequestDiffComment",
        "title": "Submit Pull Request Comment"
      },
      {
        "command": "gitcode.resolveDiffComment",
        "title": "Resolve"
      },
      {
        "command": "gitcode.unresolveDiffComment",
        "title": "Mark as Unresolved"
      },
      {
        "command": "gitcode.deletePullRequestComment",
        "title": "Delete Comment"
      },
      {
        "command": "gitcode.pullRequest.addRelatedIssue",
        "title": "GitCode: Add Related Issue to Pull Request"
      },
      {
        "command": "gitcode.pullRequest.removeRelatedIssue",
        "title": "GitCode: Unlink Related Issue from Pull Request"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitcode.createPullRequest",
          "when": "view == pr:gitcode",
          "group": "navigation@1"
        },
        {
          "command": "gitcode.signIn",
          "when": "view == pr:gitcode",
          "group": "navigation@2"
        },
        {
          "command": "gitcode.refreshPullRequests",
          "when": "view == pr:gitcode",
          "group": "navigation@3"
        },
        {
          "command": "gitcode.setPullRequestFilesLayoutTree",
          "when": "view == pr:gitcode && gitcodePullRequestFilesLayout == flat",
          "group": "navigation@4"
        },
        {
          "command": "gitcode.setPullRequestFilesLayoutFlat",
          "when": "view == pr:gitcode && gitcodePullRequestFilesLayout == tree",
          "group": "navigation@4"
        },
        {
          "command": "gitcode.createIssue",
          "when": "view == issues:gitcode",
          "group": "navigation@1"
        },
        {
          "command": "gitcode.refreshIssues",
          "when": "view == issues:gitcode",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "gitcode.openPullRequest",
          "when": "view == pr:gitcode && viewItem == pullRequest",
          "group": "inline@1"
        },
        {
          "command": "gitcode.openPullRequestOnWeb",
          "when": "view == pr:gitcode && viewItem == pullRequest",
          "group": "inline@2"
        },
        {
          "command": "gitcode.openPullRequestFile",
          "when": "view == pr:gitcode && viewItem =~ /^pullRequestFile:/",
          "group": "inline@1"
        },
        {
          "command": "gitcode.openPullRequestFileOnWeb",
          "when": "view == pr:gitcode && viewItem =~ /^pullRequestFile:/",
          "group": "inline@2"
        },
        {
          "command": "gitcode.refreshPullRequestFiles",
          "when": "view == pr:gitcode && viewItem == pullRequestFiles",
          "group": "inline@1"
        },
        {
          "command": "gitcode.openIssue",
          "when": "view == issues:gitcode && viewItem == issue",
          "group": "inline@1"
        },
        {
          "command": "gitcode.openIssueOnWeb",
          "when": "view == issues:gitcode && viewItem == issue",
          "group": "inline@2"
        },
        {
          "command": "gitcode.copyIssueUrl",
          "when": "view == issues:gitcode && viewItem == issue",
          "group": "inline@3"
        },
        {
          "command": "gitcode.useIssueAsCopilotContext",
          "when": "view == issues:gitcode && viewItem == issue",
          "group": "inline@4"
        },
        {
          "command": "gitcode.createBranchForIssue",
          "when": "view == issues:gitcode && viewItem == issue",
          "group": "inline@5"
        },
        {
          "command": "gitcode.usePullRequestAsCopilotContext",
          "when": "view == pr:gitcode && viewItem == pullRequest",
          "group": "inline@3"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "gitcode.submitPullRequestDiffComment",
          "when": "commentController == gitcode-pull-request-comments",
          "group": "navigation"
        },
        {
          "command": "gitcode.resolveDiffComment",
          "when": "commentController == gitcode-pull-request-comments && commentThread == gitcode.diffComment.unresolved",
          "group": "navigation@1"
        },
        {
          "command": "gitcode.unresolveDiffComment",
          "when": "commentController == gitcode-pull-request-comments && commentThread == gitcode.diffComment.resolved",
          "group": "navigation@1"
        },
        {
          "command": "gitcode.deletePullRequestComment",
          "when": "commentController == gitcode-pull-request-comments && commentThread =~ /gitcode.diffComment/",
          "group": "navigation@2"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "gitcode-pull-request.context",
        "name": "gitcodePullRequest",
        "fullName": "GitCode Pull Request",
        "description": "Reviews and explains the selected GitCode pull request when manually invoked."
      },
      {
        "id": "gitcode-issue.context",
        "name": "gitcodeIssue",
        "fullName": "GitCode Issue",
        "description": "Analyzes the selected GitCode issue when manually invoked."
      }
    ],
    "languageModelTools": [
      {
        "name": "gitcode_get_selected_issue",
        "displayName": "Get Selected GitCode Issue",
        "toolReferenceName": "gitcodeSelectedIssue",
        "canBeReferencedInPrompt": true,
        "icon": "$(issues)",
        "modelDescription": "Returns the currently selected GitCode issue identity and repository metadata. Use this first to check whether issue context is available before requesting larger context payloads. This tool does not edit files, commit, push, or create pull requests.",
        "userDescription": "Get the currently selected GitCode issue identity.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "gitcode_get_selected_pull_request",
        "displayName": "Get Selected GitCode Pull Request",
        "toolReferenceName": "gitcodeSelectedPullRequest",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-pull-request)",
        "modelDescription": "Returns the currently selected GitCode pull request identity and repository metadata. Use this first to check whether PR context is available before requesting larger context payloads. This tool does not edit files, commit, push, or create pull requests.",
        "userDescription": "Get the currently selected GitCode pull request identity.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "gitcode_get_issue_context",
        "displayName": "Get GitCode Issue Context",
        "toolReferenceName": "gitcodeIssueContext",
        "canBeReferencedInPrompt": true,
        "icon": "$(issues)",
        "modelDescription": "Returns the currently selected GitCode issue context from the extension, including issue detail, comments, related pull requests, and repository metadata. Use this instead of web search or public issue pages when implementing a selected GitCode issue. This tool does not edit files, commit, push, or create pull requests.",
        "userDescription": "Get selected GitCode issue context.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "gitcode_get_pull_request_context",
        "displayName": "Get GitCode Pull Request Context",
        "toolReferenceName": "gitcodePullRequestContext",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-pull-request)",
        "modelDescription": "Returns the currently selected GitCode pull request context from the extension, including pull request detail, changed files, comments, review discussions, related issues, merge state, repository metadata, and permissions. Use this instead of web search or public pull request pages when reviewing or fixing a selected GitCode pull request. This tool does not edit files, commit, push, or create pull requests.",
        "userDescription": "Get selected GitCode pull request context.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "includePatches": {
              "type": "boolean",
              "description": "Include bounded patch snippets for changed files."
            }
          }
        }
      },
      {
        "name": "gitcode_get_pull_request_files",
        "displayName": "Get GitCode Pull Request Files",
        "toolReferenceName": "gitcodePullRequestFiles",
        "canBeReferencedInPrompt": true,
        "icon": "$(files)",
        "modelDescription": "Returns changed-file summaries and optional patch snippets for the selected GitCode pull request. Use this when the agent needs to inspect specific file changes. This tool does not open local files or edit workspace files.",
        "userDescription": "Get changed files for the selected GitCode pull request.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "includePatches": {
              "type": "boolean",
              "description": "Include bounded patch snippets."
            },
            "pathFilter": {
              "type": "string",
              "description": "Optional substring filter for changed file paths."
            }
          }
        }
      },
      {
        "name": "gitcode_get_pull_request_comments",
        "displayName": "Get GitCode Pull Request Comments",
        "toolReferenceName": "gitcodePullRequestComments",
        "canBeReferencedInPrompt": true,
        "icon": "$(comment-discussion)",
        "modelDescription": "Returns timeline comments and diff review discussions for the selected GitCode pull request. Use this when the agent needs review discussion detail. This tool does not create, resolve, or delete comments.",
        "userDescription": "Get comments for the selected GitCode pull request.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "unresolvedOnly": {
              "type": "boolean",
              "description": "Return only unresolved review discussions when supported."
            }
          }
        }
      }
    ],
    "configuration": {
      "title": "GitCode",
      "properties": {
        "gitcode.baseUrl": {
          "type": "string",
          "default": "https://api.gitcode.com",
          "description": "Base URL for the GitCode API."
        },
        "gitcode.webUrl": {
          "type": "string",
          "default": "https://gitcode.com",
          "description": "Base URL for GitCode web pages."
        },
        "gitcode.repository": {
          "type": "string",
          "default": "",
          "description": "Optional GitCode repository override in owner/repo form for workspaces whose git remote is not hosted on gitcode.com."
        },
        "gitcode.pullRequests.pageSize": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of pull requests loaded into the tree."
        },
        "gitcode.pullRequests.fileListLayout": {
          "type": "string",
          "enum": [
            "tree",
            "flat"
          ],
          "default": "tree",
          "description": "Controls whether pull request files are shown as directories or a flat list."
        },
        "gitcode.issues.pageSize": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of issues loaded into the tree."
        },
        "gitcode.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "verbose"
          ],
          "default": "off",
          "description": "Trace outgoing GitCode API requests in the extension output."
        }
      }
    }
  },
  "capabilities": {
    "virtualWorkspaces": false,
    "chatParticipant": true
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "markdown-it": "^14.2.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.5"
  }
}
