{
  "name": "gitcode-pull-request",
  "displayName": "gitcode-pull-request",
  "description": "GitCode pull request integration for Visual Studio Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitcode-pull-requests",
          "title": "GitCode Pull Requests",
          "icon": "media/gitcode.svg"
        }
      ]
    },
    "views": {
      "gitcode-pull-requests": [
        {
          "id": "pr:gitcode",
          "name": "Pull Requests"
        }
      ]
    },
    "commands": [
      {
        "command": "gitcode.signIn",
        "title": "GitCode: Sign In"
      },
      {
        "command": "gitcode.refreshPullRequests",
        "title": "GitCode: Refresh Pull Requests"
      },
      {
        "command": "gitcode.openPullRequest",
        "title": "GitCode: Open Pull Request"
      },
      {
        "command": "gitcode.openPullRequestOnWeb",
        "title": "GitCode: Open Pull Request On Web"
      },
      {
        "command": "gitcode.refreshPullRequest",
        "title": "GitCode: Refresh Pull Request"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitcode.signIn",
          "when": "view == pr:gitcode",
          "group": "navigation@1"
        },
        {
          "command": "gitcode.refreshPullRequests",
          "when": "view == pr:gitcode",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "gitcode.openPullRequest",
          "when": "view == pr:gitcode && viewItem == pullRequest",
          "group": "inline@1"
        },
        {
          "command": "gitcode.openPullRequestOnWeb",
          "when": "view == pr:gitcode && viewItem == pullRequest",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "GitCode",
      "properties": {
        "gitcode.baseUrl": {
          "type": "string",
          "default": "https://api.gitcode.com",
          "description": "Base URL for the GitCode API."
        },
        "gitcode.webUrl": {
          "type": "string",
          "default": "https://gitcode.com",
          "description": "Base URL for GitCode web pages."
        },
        "gitcode.repository": {
          "type": "string",
          "default": "",
          "description": "Optional GitCode repository override in owner/repo form for workspaces whose git remote is not hosted on gitcode.com."
        },
        "gitcode.pullRequests.pageSize": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of pull requests loaded into the tree."
        },
        "gitcode.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "verbose"
          ],
          "default": "off",
          "description": "Trace outgoing GitCode API requests in the extension output."
        }
      }
    }
  },
  "capabilities": {
    "virtualWorkspaces": false
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "markdown-it": "^14.2.0"
  }
}
